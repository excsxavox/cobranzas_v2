# Copiar a .env y ajustar valores reales

# SQLite (desarrollo)
DATABASE_URL=sqlite:///data/BD_Cobranza.sqlite
PERSISTIR_EN_BD=true

# SQL Server (producción — descomentar si aplica)
# DB_DRIVER=ODBC Driver 18 for SQL Server
# DB_SERVER=.\SQLEXPRESS
# DB_DATABASE=BD_Cobranza
# DB_USER=
# DB_PASSWORD=
# DB_TRUSTED_CONNECTION=no
# DB_TRUST_SERVER_CERTIFICATE=yes
# DB_ENCRYPT=yes

# Asesores (Job 0)
ARCHIVO_EXCEL_ASESORES=data/catalogo/asesores.xlsx
SYNC_ASESORES_RECHAZAR_DUPLICADOS=true

# Feriados (Job 0b)
DIRECTORIO_EXCEL_FERIADOS=data/catalogo
PATRON_EXCEL_FERIADOS=dias_feriados.xlsx
CLAVE_FERIADOS=feriados_catalogo

# Rutas core
DOCSMORA_DIR=docsmora
DESTINO_DIR=destino
USAR_RUTAS_AUTOMATICAS=true
# FECHA_CORTE=05052026

# Mora temprana (HU-GRC-01)
USAR_MORA_TEMPRANA=true
USAR_REGLAS_BD=false
MORA_TEMPRANA_DIAS_MIN=1
MORA_TEMPRANA_DIAS_MAX=0
ESTADOS_EXCLUIDOS=CASTIGADO,JUDICIAL,GESTION JUDICIAL
TIPOS_OPER_EXCLUIDOS=COMPRA CARTERA,COMPRACARP

# Recblue
# ARCHIVO_RECBLUE=
# USAR_RECBLUE_SQL=false

# API
API_HOST=127.0.0.1
API_PORT=8000

# Notificaciones por correo (módulo compartido src/notificaciones)
NOTIFICACIONES_ERRORES_HABILITADO=false
# Catálogo dbo.notificaciones vía API REST (:8002) + SMTP en el servicio de notificaciones
NOTIFICACIONES_API_HOST=127.0.0.1
NOTIFICACIONES_API_PORT=8002
# NOTIFICACIONES_API_URL=http://127.0.0.1:8002
NOTIFICACIONES_API_TIMEOUT=30
# SMTP_* se configuran en el servicio notificaciones (notificaciones api)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=
# SMTP_USE_TLS=true
# SMTP_USE_SSL=false

LOG_LEVEL=INFO
LOG_DIR=logs
